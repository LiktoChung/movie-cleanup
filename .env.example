# Get a free API key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_api_key_here

# Movie library to scan
LIBRARY_PATH=\\path\to\your\movie\library

# Quarantine destination (duplicates are moved here, not deleted)
QUARANTINE_PATH=\\path\to\your\quarantine\directory

# Web server port
PORT=8765
